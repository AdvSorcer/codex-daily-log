datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  logs      Log[]
  createdAt DateTime @default(now())
}

model AuthRateLimit {
  id          String   @id @default(cuid())
  action      String
  key         String
  count       Int
  windowStart DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([action, key])
  @@index([updatedAt])
}

model Log {
  id        String   @id @default(cuid())
  date      DateTime
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, date])
}

enum Role {
  ADMIN
  USER
}
